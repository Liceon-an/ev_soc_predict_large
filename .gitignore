# ==============================
# 毕业论文项目 必须忽略的大文件
# 数据集、图片、日志、临时文件
# ==============================

# 数据文件夹（完全不上传）
/data/
/raw_data/
/dataset/

# 绘图、结果图、分析图（完全不上传）
/plots/
/analysis_plots/
/figures/
/results/

# 训练日志、输出文件（不上传）
/logs/
/temp/
/output/
/checkpoint/
/checkpoints/

# 模型权重、大文件（不上传）
*.pth
*.pt
*.pkl
*.h5
*.hdf5
*.ckpt

# 数据文件（全部忽略）
*.csv
*.xlsx
*.xls
*.parquet
*.txt
*.json
*.zip
*.rar
*.7z
*.tar.gz

# 图片文件（忽略所有）
*.png
*.jpg
*.jpeg
*.gif
*.bmp
*.svg
*.pdf

# 日志文件
*.log
*.out

# Python 缓存
__pycache__/
*.pyc
*.pyo
*.pyd

# IDE 与系统文件
.vscode/
.idea/
.DS_Store
*.swp
*.tmp

# Jupyter  notebook 检查点
.ipynb_checkpoints/